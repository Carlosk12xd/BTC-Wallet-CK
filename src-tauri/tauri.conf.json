{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CarlosK Wallet",
  "version": "0.80.0",
  "identifier": "com.carloskxd12.carloskwallet",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CarlosK Wallet",
        "width": 1120,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
