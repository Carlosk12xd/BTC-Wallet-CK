#[cfg_attr(mobile, tauri::mobile_entry_point)]
pub fn run() {
    tauri::Builder::default()
        .manage(AppState {
            wallet: Mutex::new(None),
            bolt12_offer: Mutex::new(None),
        })
        .invoke_handler(tauri::generate_handler![
            create_mining_wallet,
            restore_mining_wallet,
            export_encrypted_wallet_backup,
            restore_encrypted_wallet_backup,
            sign_ocean_message,
            save_bolt12_offer,
            get_bolt12_offer,
            generate_bolt12_offer_in_app,
            ldk_spike_status,
            in_app_bolt12_status,
            open_source_status,
            build_ocean_pool_config,
            inspect_ocean_message,
            check_ocean_lightning_pairing,
            lightning_prototype_plan,
            lightning_receive_readiness,
            default_signet_node_config,
            start_signet_node_preview,
            lightning_safety_checklist,
            ldk_node_experimental_status,
            preview_signet_bolt12_offer,
            ldk_dependency_manifest,
            build_signet_funding_plan,
            ldk_runtime_status,
            build_ldk_runtime_preflight,
            signet_offer_acceptance_test,
            ldk_signet_branch_status,
            build_ldk_signet_runtime_start_plan,
            ldk_signet_offer_recipe,
            ldk_real_signet_prototype_status,
            preview_ldk_real_signet_start,
            ldk_signet_funding_address_status,
            preview_ldk_signet_funding_address,
            ldk_signet_funding_address_acceptance_plan,
            functional_viability_status,
            build_release_gate_report,
            build_ocean_setup_bundle,
            build_doctor_status,
            build_local_validation_plan,
            build_miner_runbook,
            build_mvp_flow_report,
            build_acceptance_report,
            product_mvp_status,
            build_e2e_harness_report,
            redact_for_issue,
            build_first_run_wizard_report,
            build_external_release_report,
            build_ocean_dashboard_report,
            build_signet_runtime_fixture_report,
            get_payout_pool_presets,
            estimate_mining_payout,
            storage_roadmap,
            get_default_miner_profiles
        ])
        .run(tauri::generate_context!())
        .expect("error while running CarlosK Wallet");
}

fn main() {
    run();
}
